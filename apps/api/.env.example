# Copy to .env. Local default matches docker-compose.yml at repo root.
DATABASE_URL="postgresql://rent:rent@localhost:5432/rentmonitoring?schema=public"

PORT=3001
NODE_ENV=development

# Auth — generate a strong secret: `openssl rand -hex 32`
JWT_SECRET="change-me-to-a-32+char-random-secret-string"
JWT_EXPIRES_IN="7d"
# Bootstrap admin created by `pnpm db:seed`.
ADMIN_EMAIL="admin@rent.local"
ADMIN_PASSWORD="changeme123"
